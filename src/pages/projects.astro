---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { fetchShowcaseProjects } from "../lib/github";
import { SITE } from "../lib/config";

const projects = await fetchShowcaseProjects();
---

<BaseLayout
  title="Projects"
  description={`Software projects by ${SITE.name}. ${SITE.tagline}`}
>
  <section class="section">
    <div class="page-header animate-on-scroll">
      <p class="section-label">Projects</p>
      <h2>Things I've Built</h2>
      <p>
        Each project here has a <code>SHOWCASE.md</code> in its repo. If you see
        it here, I'm proud of it.
      </p>
    </div>

    {projects.length > 0 ? (
      <div class="projects-grid">
        {projects.map((project, i) => (
          <ProjectCard project={project} index={i} />
        ))}
      </div>
    ) : (
      <div class="empty-state animate-on-scroll">
        <p>Projects are loaded from GitHub repos that contain a <code>SHOWCASE.md</code> file.</p>
        <p>Check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 48px;
  }

  .page-header p {
    margin-top: 8px;
  }

  code {
    font-family: var(--font);
    font-size: 0.85em;
    background: var(--bg-alt);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .empty-state {
    padding: 60px 0;
    text-align: center;
  }

  .empty-state p {
    margin: 0 auto 8px;
  }
</style>
