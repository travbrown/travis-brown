---
import { SITE } from "../lib/config";

const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/contact", label: "Contact" },
];
---

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo" transition:name="logo">{SITE.name.split(" ")[0].toLowerCase()}<span class="cursor">_</span></a>
    <ul class="nav-links">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["nav-link", { active: currentPath === link.href }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<script>
  function initNav() {
    const toggle = document.querySelector(".nav-toggle");
    const links = document.querySelector(".nav-links");
    if (!toggle || !links) return;

    toggle.addEventListener("click", () => {
      const open = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!open));
      links.classList.toggle("open");
    });
  }

  initNav();
  document.addEventListener("astro:after-swap", initNav);
</script>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
    background: rgba(250, 250, 250, 0.9);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-weight: 700;
    font-size: 1.1rem;
    border: none;
    letter-spacing: -0.02em;
  }

  .cursor {
    animation: blink 1s step-end infinite;
    color: var(--text-faint);
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-link {
    font-size: 0.85rem;
    color: var(--text-muted);
    border: none;
    position: relative;
    padding-bottom: 2px;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--text);
    transition: width var(--transition);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-link.active {
    color: var(--text);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text);
    transition: var(--transition);
  }

  .nav-toggle[aria-expanded="true"] span:first-child {
    transform: rotate(45deg) translate(2px, 2px);
  }

  .nav-toggle[aria-expanded="true"] span:last-child {
    transform: rotate(-45deg) translate(2px, -2px);
  }

  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      max-height: 0;
      overflow: hidden;
      transition: max-height var(--transition);
    }

    .nav-links.open {
      max-height: 200px;
    }

    .nav-links li {
      padding: 12px 24px;
    }

    .nav-inner {
      padding: 0 16px;
    }
  }
</style>
