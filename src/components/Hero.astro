---
import { SITE } from "../lib/config";
---

<section class="hero">
  <div class="hero-portrait">
    <div class="portrait-frame">
      <img
        src="/images/portrait.jpg"
        alt={`Portrait of ${SITE.name}`}
        width="280"
        height="280"
        loading="eager"
      />
    </div>
  </div>

  <div class="hero-text">
    <h1 transition:name="name">{SITE.name}</h1>
    <p class="tagline">
      <span class="tagline-text">{SITE.tagline}</span><span class="tagline-cursor">|</span>
    </p>
    <p class="bio">{SITE.description}</p>
    <div class="hero-cta">
      <a href="/projects" class="cta-primary">View Work</a>
      <a href="/contact" class="cta-secondary">Get in Touch</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100dvh - 60px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 40px;
    padding: 60px 0;
  }

  .portrait-frame {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--border);
    animation: fadeIn 1s ease-out;
  }

  .portrait-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter 0.6s ease;
  }

  .portrait-frame:hover img {
    filter: grayscale(0%);
  }

  .hero-text {
    animation: fadeUp 0.8s ease-out;
  }

  h1 {
    margin-bottom: 12px;
  }

  .tagline {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    color: var(--text-muted);
    margin-bottom: 24px;
    max-width: none;
  }

  .tagline-text {
    display: inline;
  }

  .tagline-cursor {
    animation: blink 1s step-end infinite;
    color: var(--text-faint);
    margin-left: 2px;
  }

  .bio {
    margin: 0 auto 32px;
    font-size: 1rem;
    line-height: 1.8;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-primary,
  .cta-secondary {
    padding: 10px 28px;
    font-family: var(--font);
    font-size: 0.85rem;
    border-radius: var(--radius);
    transition:
      background var(--transition),
      color var(--transition),
      transform var(--transition);
  }

  .cta-primary {
    background: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    border-color: var(--text);
  }

  .cta-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .cta-secondary:hover {
    border-color: var(--text);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 40px 0;
      min-height: auto;
    }

    .portrait-frame {
      width: 160px;
      height: 160px;
    }
  }
</style>
